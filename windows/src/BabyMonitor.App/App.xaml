<?xml version="1.0" encoding="utf-8"?>
<!--
  UI-1: dark, always. This app is read at 3am in a dark room, and a white flash costs a parent their
  night vision. It is the one place the app deliberately ignores the system's light theme.
-->
<Application
    x:Class="BabyMonitor.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- The glass the chrome floats on. The picture is the interface; the controls sit above it. -->
            <AcrylicBrush x:Key="ChromeBrush"
                          TintColor="#0B0B0F"
                          TintOpacity="0.55"
                          TintLuminosityOpacity="0.35"
                          FallbackColor="#E6101014" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
