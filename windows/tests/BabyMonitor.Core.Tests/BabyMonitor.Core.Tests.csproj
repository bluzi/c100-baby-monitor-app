<Project Sdk="Microsoft.NET.Sdk">

  <!--
    THE SPEC SUITE, again.

    Every test here is a port of the one in core/src/commonTest that carries the same criterion ID.
    That is the whole point: Windows could not consume the Kotlin core, so the monitor was written a
    second time — and a second implementation of a baby monitor is only safe if it is held to the
    same evidence. The interop vectors (core/protocol-vectors.json, generated from the proven c100
    implementation) pin the wire byte for byte; these tests pin the behaviour.

    It targets plain net8.0, so it runs on any machine — including the Mac this port was written on.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RootNamespace>BabyMonitor.Core.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/BabyMonitor.Core/BabyMonitor.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The one file both implementations are measured against. Shared, never copied. -->
    <None Include="../../../core/protocol-vectors.json" Link="protocol-vectors.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
